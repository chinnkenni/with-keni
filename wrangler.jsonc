{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "with-keni",
	"compatibility_date": "2026-06-13",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./dist",
		"not_found_handling": "404-page"
	},
	"routes": [
		{
			"pattern": "withkeni.com",
			"custom_domain": true
		},
		{
			"pattern": "www.withkeni.com",
			"custom_domain": true
		}
	],
	"observability": {
		"enabled": true
	}
}
