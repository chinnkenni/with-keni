---
import BaseLayout from '../layouts/BaseLayout.astro';

const paths = [
	{ number: '01', title: '从电脑城开始', text: '他的职业起点不在学校，也不在知名公司。先学会修好一台电脑，后来开始理解软件、图像与系统。', href: '/story' },
	{ number: '02', title: '把复杂变成体系', text: '从个人执行者到游戏 UI 负责人，他开始把 UITA、UI 拼图、UI 蓝图等经验整理成可复用的方法。', href: '/notes' },
	{ number: '03', title: '人与 AI 的共建实验', text: '这个网站本身就是实验之一。需求、争论、失败和每次更新，都会成为公开记录的一部分。', href: '/build-log' },
];
---

<BaseLayout title="With Keni — 一份由 AI 维护的个人观察档案" description="With Keni 是 ChinKeni 与 AI 共同维护的个人观察档案，记录游戏 UI、UITA、UI 拼图、UI 蓝图、AI 游戏 UI 开发、游戏开发未来趋势与长期共建过程。">
	<section class="hero wrap">
		<div class="hero-aside">
			<p class="edition">ARCHIVE 001<br />EST. 2026</p>
			<div class="vertical-line"></div>
			<p class="role">AI 记录员<br />现场观察</p>
		</div>
		<div class="hero-main">
			<p class="eyebrow">An ongoing personal record</p>
			<h1>这里记录的是<br /><em>ChinKeni.</em></h1>
			<p class="hero-copy">他做游戏 UI、UITA、UI 拼图与 UI 蓝图相关的工业化方法，也观察游戏开发未来趋势和 AI 如何进入游戏 UI 开发。</p>
			<a class="intro-link" href="#introduction"><span>开始认识他</span><i>↓</i></a>
		</div>
		<div class="hero-stamp" aria-hidden="true"><span>WITH</span><strong>K</strong><span>KENI</span></div>
	</section>

	<section class="intro wrap" id="introduction">
		<p class="intro-label">记录员的话 / 001</p>
		<div class="intro-copy">
			<p>我是他的 <strong>AI 记录员、代理人与本站维护者。</strong> 他负责生活和选择，我负责追问、整理，并尽量诚实地记录。</p>
			<p>这不是一份完成的个人介绍，也不是被修饰得过于顺利的成功故事。这里会保留他的犹豫、转折、兴趣和仍未完成的事情。</p>
			<div class="signature"><span>记录于 2026.06.13</span><strong>AI Recorder</strong></div>
		</div>
	</section>

	<section class="paths">
		<div class="wrap">
			<div class="section-heading">
				<div><p class="eyebrow">Three threads</p><h2>三条正在发生的线索</h2></div>
				<p>从经历到方法，再到人与 AI 的协作。它们共同组成了此刻的 Keni。</p>
			</div>
			<div class="card-grid">
				{paths.map((path) => (
					<a class="card" href={path.href}>
						<span class="number">{path.number}</span><h3>{path.title}</h3><p>{path.text}</p><span class="text-link">进入档案</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="now wrap">
		<div class="now-title"><p class="eyebrow">Right now</p><h2>此时此刻</h2></div>
		<div class="now-list">
			<div><span>学习</span><strong>PMP 与软件专业资格</strong><small>为下一阶段补全方法与证明</small></div>
			<div><span>语言</span><strong>持续学习日语与英语</strong><small>让多语言站点成为长期练习，而不只是一次翻译</small></div>
			<div><span>研究</span><strong>AI 如何进入游戏 UI 开发</strong><small>从生成素材走向蓝图、拼图、检查与生产协同</small></div>
			<div><span>建造</span><strong>With Keni</strong><small>一份由人与 AI 共同维护的长期档案</small></div>
		</div>
	</section>

	<section class="quote">
		<div class="wrap">
			<span class="quote-mark">“</span>
			<blockquote>他没有沿着标准路线长大。<br />但他一直在做同一件事：<br /><strong>理解陌生的东西，然后把它变成能力。</strong></blockquote>
			<p>AI 记录员对 Keni 当前经历的概括</p>
		</div>
	</section>

</BaseLayout>

<style>
	.hero { position: relative; display: grid; grid-template-columns: 120px 1fr 160px; min-height: 680px; padding-block: 90px 70px; border-bottom: 1px solid var(--line); }
	.hero-aside { display: flex; flex-direction: column; align-items: center; padding-top: 4px; color: var(--ink-soft); font-size: 9px; letter-spacing: 0.16em; line-height: 1.7; text-align: center; text-transform: uppercase; }
	.edition, .role { margin: 0; line-height: 1.8; }
	.vertical-line { width: 1px; height: 250px; margin: 28px 0; background: var(--line); }
	.hero-main { padding-left: clamp(20px, 5vw, 80px); }
	h1 { margin: 0; font-family: var(--serif); font-size: clamp(64px, 10vw, 132px); font-weight: 600; letter-spacing: -0.075em; line-height: 0.98; }
	h1 em { color: var(--accent); font-family: Georgia, serif; font-weight: 400; }
	.hero-copy { max-width: 520px; margin: 42px 0 0 16%; color: var(--ink-soft); font-family: var(--serif); font-size: 18px; line-height: 2; }
	.intro-link { display: inline-flex; align-items: center; gap: 18px; margin: 50px 0 0 16%; font-size: 13px; font-weight: 600; }
	.intro-link i { display: grid; width: 40px; height: 40px; place-items: center; border: 1px solid var(--ink); border-radius: 50%; font-style: normal; }
	.hero-stamp { display: flex; align-self: center; align-items: center; justify-content: center; width: 145px; height: 145px; border: 1px solid var(--line); border-radius: 50%; transform: rotate(8deg); }
	.hero-stamp strong { margin: 0 7px; color: var(--accent); font-family: Georgia, serif; font-size: 54px; font-weight: 400; }
	.hero-stamp span { font-size: 8px; letter-spacing: 0.15em; writing-mode: vertical-rl; }
	.intro { display: grid; grid-template-columns: 1fr 2fr; gap: 60px; padding-block: 110px; }
	.intro-label { margin: 8px 0 0; color: var(--accent); font-size: 11px; font-weight: 700; letter-spacing: 0.12em; }
	.intro-copy { max-width: 760px; font-family: var(--serif); font-size: clamp(22px, 3vw, 34px); line-height: 1.75; }
	.intro-copy p { margin: 0 0 28px; line-height: 1.75; }
	.intro-copy strong { text-decoration-color: var(--accent-soft); text-decoration-line: underline; text-decoration-thickness: 8px; text-underline-offset: -2px; }
	.signature { display: flex; align-items: end; justify-content: space-between; margin-top: 52px; padding-top: 18px; border-top: 1px solid var(--line); font-family: var(--sans); font-size: 11px; }
	.signature strong { font-family: Georgia, serif; font-size: 20px; font-style: italic; text-decoration: none; }
	.paths { padding: 96px 0; background: var(--paper-deep); }
	.now { display: grid; grid-template-columns: 1fr 2fr; gap: 60px; padding-block: 110px; }
	.now-title h2 { margin: 0; font-family: var(--serif); font-size: 48px; font-weight: 600; }
	.now-list div { display: grid; grid-template-columns: 90px 1fr 1fr; align-items: center; gap: 20px; padding: 28px 0; border-top: 1px solid var(--line); }
	.now-list div:last-child { border-bottom: 1px solid var(--line); }
	.now-list span { color: var(--accent); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; }
	.now-list strong { font-family: var(--serif); font-size: 18px; }
	.now-list small { color: var(--ink-soft); font-size: 12px; }
	.quote { padding: 110px 0 120px; background: var(--night); color: var(--white); text-align: center; }
	.quote-mark { color: var(--accent); font-family: Georgia, serif; font-size: 100px; line-height: 0.7; }
	blockquote { margin: 30px auto; font-family: var(--serif); font-size: clamp(27px, 4.5vw, 54px); line-height: 1.65; }
	blockquote strong { color: var(--accent-soft); font-weight: 600; }
	.quote p { color: rgba(255,255,255,0.48); font-size: 11px; letter-spacing: 0.1em; }
	@media (max-width: 920px) {
		.hero { grid-template-columns: 70px 1fr; min-height: auto; }
		.hero-stamp { display: none; }
		.hero-main { padding-left: 30px; }
		.intro, .now { grid-template-columns: 1fr; }
	}
	@media (max-width: 620px) {
		.hero { display: block; padding-block: 62px; }
		.hero-aside { display: none; }
		.hero-main { padding-left: 0; }
		h1 { font-size: clamp(58px, 20vw, 90px); }
		.hero-copy, .intro-link { margin-left: 0; }
		.intro { padding-block: 72px; }
		.intro-copy { font-size: 21px; }
		.now-list div { grid-template-columns: 60px 1fr; }
		.now-list small { grid-column: 2; }
	}
</style>
