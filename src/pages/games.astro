---
import GameProjectsContent from '../components/GameProjectsContent.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const gamesContent = {
	sectionTitle: '游戏入口',
	sectionCopy: '一个游戏一张卡片。保留截图、访问地址和简短介绍，方便直接打开体验。',
	placeholder: '等待截图',
	projects: [
		{
			status: 'AI GAME 01',
			title: '旧城回身',
			text: '短局叙事游戏。三小时后，雾港会被旧城吞回过去；你要弄明白，自己是被塔档叫回来的调查员，还是旧城等了很多年的王。',
			href: 'https://game001.withkeni.com/',
			action: '开始游戏',
			image: '/images/games/old-city-return.jpg',
			alt: '《旧城回身》游戏封面，雾港旧城街区与标题文字',
		},
		{
			status: 'AI GAME 02',
			title: '梦境记忆',
			text: '月相拼图式的短局梦境游戏。醒来以前，你听见旧校门的铃声，沿着散落的姓名、票根、磁带和练习本，进入更深的记忆，把自己带回清晨。',
			href: 'https://game002.withkeni.com/',
			action: '进入梦境',
			image: '/images/games/dream-memory.jpg',
			alt: '《梦境记忆》游戏封面，旧校门、月亮、飘散卡片与梦境入口界面',
		},
	],
};
---

<BaseLayout
	title="游戏项目 — With Keni"
	description="With Keni 的 AI 游戏项目入口，收录《旧城回身》《梦境记忆》等游戏链接、截图和简介。"
	active="games"
	pagePath="games"
>
	<section class="page-intro wrap">
		<p class="eyebrow">AI game projects</p>
		<h1>游戏项目<br />入口合集</h1>
		<p class="lead">这里不写复杂开发长文，只放一个个游戏入口。截图、地址和简介准备好后，就把对应游戏补成可点击卡片。</p>
	</section>
	<GameProjectsContent content={gamesContent} />
</BaseLayout>
