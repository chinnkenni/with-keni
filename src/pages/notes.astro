---
import BaseLayout from '../layouts/BaseLayout.astro';
const notes = [
	['记录员观察', '真正的升级，不是学会更多工具', 'Keni 的职业变化发生在他开始把个人经验变成团队系统之后。工具只是表面，判断与组织才是长期能力。'],
	['游戏 UI 方法', '从 UI 拼图到 UI 蓝图', 'UITA、UI 拼图、UI 蓝图和游戏 UI 工业化，不只是几个工具名。它们更像 Keni 在靠近游戏 UI 总监角色时形成的方法：把复杂界面拆成结构，把重复生产变成标准，把个人经验交给团队复用。'],
	['趋势观察', 'AI 会先改变游戏 UI 的生产方式', '游戏开发的未来趋势未必只是“AI 直接生成游戏”。更现实的变化会先发生在 UI 资产整理、界面蓝图、拼图式复用、规范检查、动效草案和多语言适配里。对 Keni 来说，AI 应用于游戏 UI 开发的价值，是把重复劳动变少，把团队判断、验证和迭代速度变强。'],
	['Keni 口述整理', '语言先从需要使用的地方开始', '日语起于一次去日本旅行前的准备，他先学了一些用于基础沟通的高频词。英语则来自编程与技术文档：长期接触让他积累了常见的开发词汇，但日常表达和语法仍是明显缺口。下一步，他希望把语言能力从“能看懂工作内容”扩展到日常生活与商业交流。'],
	['Keni 口述整理', '关于那些照顾过我的人', '职业路上的几个关键转折，都有人愿意给一个尚未完全准备好的人机会。这些人的名字未必适合公开，但影响值得留下。'],
	['职业思考', '学历、能力与迟到的证明', '证书不会替代已经发生过的工作，但它可以补全进入下一扇门所需要的语言。'],
];
---
<BaseLayout title="观察笔记 — With Keni" description="AI 记录员整理 ChinKeni 关于游戏 UI、UITA、UI 拼图、UI 蓝图、AI 游戏 UI 开发、游戏开发未来趋势与职业判断的观察。" active="notes" pagePath="notes">
	<section class="page-intro wrap"><p class="eyebrow">Notes & reflections</p><h1>一些事发生以后，<br />才慢慢显出意义</h1><p class="lead">故事由记录员整理，观点由 Keni 负责。无法确认的部分会明确标注，真实比完整更重要。</p></section>
	<section class="content-section wrap"><div class="card-grid">
		{notes.map(([type, title, text], index) => (
			<article class="card"><span class="number">{type} / 0{index + 1}</span><h3>{title}</h3><p>{text}</p><span class="text-link">待展开记录</span></article>
		))}
	</div></section>
</BaseLayout>
