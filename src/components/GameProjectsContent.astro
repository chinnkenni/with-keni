---
interface Project {
	status: string;
	title: string;
	text: string;
	href?: string;
	action: string;
	image?: string;
	alt?: string;
	imagePosition?: string;
}

interface Props {
	content: {
		sectionTitle: string;
		sectionCopy: string;
		placeholder: string;
		projects: Project[];
	};
}

const { content } = Astro.props;
---

<section class="game-section wrap">
	<div class="section-heading">
		<h2>{content.sectionTitle}</h2>
		<p>{content.sectionCopy}</p>
	</div>
	<div class="game-list">
		{content.projects.map((project) => (
			project.href ? (
				<a class="game-card" href={project.href} target="_blank" rel="noopener noreferrer">
					<figure class:list={['game-thumb', { empty: !project.image }]}>
						{project.image ? (
							<img
								src={project.image}
								alt={project.alt ?? project.title}
								loading="lazy"
								style={project.imagePosition ? `object-position: ${project.imagePosition}` : undefined}
							/>
						) : (
							<span>{content.placeholder}</span>
						)}
					</figure>
					<div class="game-card-copy">
						<span class="number">{project.status}</span>
						<h3>{project.title}</h3>
						<p>{project.text}</p>
						<span class="text-link">{project.action}</span>
					</div>
				</a>
			) : (
				<article class="game-card">
					<figure class:list={['game-thumb', { empty: !project.image }]}>
						{project.image ? (
							<img
								src={project.image}
								alt={project.alt ?? project.title}
								loading="lazy"
								style={project.imagePosition ? `object-position: ${project.imagePosition}` : undefined}
							/>
						) : (
							<span>{content.placeholder}</span>
						)}
					</figure>
					<div class="game-card-copy">
						<span class="number">{project.status}</span>
						<h3>{project.title}</h3>
						<p>{project.text}</p>
						<span class="text-link">{project.action}</span>
					</div>
				</article>
			)
		))}
	</div>
</section>

<style>
	.game-section { padding: 72px 0; }
	.game-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 360px));
		align-items: stretch;
		gap: 22px;
	}
	.game-card {
		display: grid;
		grid-template-rows: auto 1fr;
		min-height: 0;
		border: 1px solid var(--line);
		background: rgba(255, 253, 247, .34);
		transition: background 180ms ease, transform 180ms ease;
	}
	a.game-card:hover { background: rgba(255, 253, 247, .72); transform: translateY(-4px); }
	.game-thumb {
		display: grid;
		aspect-ratio: 4 / 5;
		min-height: 0;
		margin: 0;
		place-items: center;
		border-bottom: 1px solid var(--line);
		background:
			linear-gradient(rgba(23, 23, 19, .035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(23, 23, 19, .025) 1px, transparent 1px),
			rgba(231, 225, 212, .42);
		background-size: 24px 24px;
		overflow: hidden;
	}
	.game-thumb:not(.empty) { background: #11110f; }
	.game-thumb img { display: block; width: 100%; height: 100%; object-fit: cover; object-position: center; }
	.game-thumb span {
		color: rgba(88, 87, 79, .58);
		font-size: 12px;
		letter-spacing: .12em;
		text-transform: uppercase;
	}
	.game-card-copy { display: flex; flex-direction: column; padding: 24px; }
	.game-card h3 {
		margin: 24px 0 12px;
		font-family: var(--serif);
		font-size: clamp(28px, 3vw, 36px);
		font-weight: 600;
		line-height: 1.25;
	}
	.game-card p { margin: 0; color: var(--ink-soft); font-size: 13px; line-height: 1.9; }
	.game-card .text-link { margin-top: auto; padding-top: 24px; }
	a.game-card .text-link::after { content: '↗'; }
	article.game-card .text-link::after { content: '→'; }
	@media (max-width: 680px) {
		.game-list { grid-template-columns: minmax(260px, 360px); justify-content: center; }
	}
	@media (max-width: 480px) {
		.game-list { grid-template-columns: 1fr; }
	}
</style>
